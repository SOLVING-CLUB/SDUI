# ── SDUI web app + layout API (Next.js) ─────────────────────────────
# Copy to .env.local for local use, or add these in Vercel → Settings →
# Environment Variables for deployment.

# Supabase config store. Leave BOTH unset locally to use the file-based
# store (data/ folder) — no database needed for local dev.
SUPABASE_URL=https://kqpulltdjxkdwpolvesq.supabase.co

# Supabase dashboard → SDUI project → Project Settings → API Keys → service_role.
# SERVER-ONLY SECRET: bypasses row-level security. Never expose to browsers,
# never commit a real value to git.
SUPABASE_SERVICE_ROLE_KEY=

# Any secret string you invent. When set, publish/rollback/draft-save require it.
# Authorize your browser once on /admin via console:
#   localStorage.setItem("adminToken", "<same value>")
ADMIN_TOKEN=

# ── Mobile app (mobile/.env) ────────────────────────────────────────
# Where the Expo app fetches layouts from. Use your Vercel URL once deployed,
# or http://<your-mac-lan-ip>:3000 while developing against local `npm run dev`.
# EXPO_PUBLIC_API_URL=https://your-project.vercel.app
